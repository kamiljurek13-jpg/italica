# Anthropic API Key for Claude AI recommendations (BACKEND ONLY - Vercel)
# Get your API key from: https://console.anthropic.com/
# NOTE: This is used in the serverless function (api/recommendations.ts)
# For Vercel deployment, add this as an environment variable in Vercel dashboard
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Amplitude Analytics API Key (Frontend - safe to expose)
# Get your API key from: https://analytics.amplitude.com/
VITE_AMPLITUDE_API_KEY=your_amplitude_api_key_here

# Pexels API Key for high-quality product images (Local script only)
# Get your FREE API key from: https://www.pexels.com/api/
VITE_PEXELS_API_KEY=your_pexels_api_key_here
